<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css" rel="stylesheet" />   
    <link rel="stylesheet" href="/styles.css">
    <title>Operaciones - Alpha 1 </title>
</head>
<body>
  <%- include("partials/topbar") %>
  <%- include("partials/sidebar") %>
  <div id="overlay" class="overlay"></div>


 <main class="dashboard">

    <div class="card">
        <h5 class="card-title">Total de Clientes</h5>
        <h6 class="card-subtitle"> </h6>
        <p class="card-nmb">1,248</p>
    </div>

    <div class="card">
        <h5 class="card-title">Clientes Activos</h5>
        <h6 class="card-subtitle"> </h6>
        <p class="card-nmb">1,102</p>
    </div>

    <div class="card">
        <h5 class="card-title">Nuevos Clientes</h5>
        <h6 class="card-subtitle">(última semana)</h6>
        <p class="card-nmb">38</p>
    </div>

    <div class="card">
        <h5 class="card-title">Clientes con Alertas</h5>
        <h6 class="card-subtitle">  </h6>
        <p class="card-nmb">50</p>
    </div>

    <section class="panel full-page">

    <div class="table-tabs">
        <button class="tab-btn active" data-table="clientes-section">Clientes</button>
        <button class="tab-btn" data-table="bloqueados-section">Personas Bloqueadas</button>
    </div>

    <div id="clientes-section" class="table-section active">
        <h2>Listado de Clientes</h2>
        <div id="clientes-table"></div>
    </div>

    <div id="bloqueados-section" class="table-section">
        <h2>Personas Bloqueadas</h2>
        <div id="bloqueados-table"></div>
    </div>

    </section>

</main>
<script src="https://unpkg.com/gridjs/dist/gridjs.umd.js"></script>
<script src="/scripts/componentes.js"></script>
<script src="/scripts/clientes.js"></script>
</body>
</html>