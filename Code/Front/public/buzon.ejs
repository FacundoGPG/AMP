<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buzón Interno</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
  <link href="https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css" rel="stylesheet" />   
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

  <!-- COMPONENTES -->
  <%- include("partials/topbar") %>
  <%- include("partials/sidebar") %>
  <div id="overlay" class="overlay"></div>

  <!-- CONTENIDO -->
  <main class="buzon-page">

    <!-- HEADER -->
    <section class="buzon-header">
      <h1>Buzón Interno</h1>
      <p>Canal seguro para reportar operaciones o situaciones inusuales</p>
    </section>

    <!-- CARDS -->
    <section class="buzon-cards">
      <div class="buzon-card">
        <p>Total de reportes</p>
        <h2>24</h2>
      </div>

      <div class="buzon-card">
        <p>Pendientes</p>
        <h2>8</h2>
      </div>

      <div class="buzon-card">
        <p>En seguimiento</p>
        <h2>10</h2>
      </div>

      <div class="buzon-card">
        <p>Resueltos</p>
        <h2>6</h2>
      </div>
    </section>

    <!-- LAYOUT -->
    <section class="buzon-layout">

      <!-- TABLA -->
      <section class="buzon-panel">
        <div class="buzon-panel-header">
          <h2>Bandeja de reportes</h2>
        </div>

        <div id="reportes-table"></div>
      </section>

      <!-- DETALLE -->
      <aside class="buzon-panel detail-panel">

        <div class="buzon-panel-header">
          <h2>Detalle del reporte</h2>
        </div>

        <div class="detail-title">
          <h3 id="detail-id">Selecciona un reporte</h3>
          <span id="detail-status" class="status pending">---</span>
        </div>

        <div class="detail-grid">
          <div>
            <p>Fecha:</p>
            <strong id="detail-date">---</strong>
          </div>

          <div>
            <p>Canal:</p>
            <strong>Anónimo</strong>
          </div>
        </div>

        <div class="detail-block">
          <p>Descripción:</p>
          <span id="detail-description">
            Selecciona un reporte para ver el detalle
          </span>
        </div>

        <div class="detail-block">
          <p>Evidencia:</p>

          <div class="file-item">
            <span>Sin archivos</span>
          </div>
        </div>

        <label>Estatus:</label>
        <select id="detail-select" class="detail-select">
          <option>Pendiente</option>
          <option>En seguimiento</option>
          <option>Resuelto</option>
        </select>

        <label>Responsable:</label>
        <select class="detail-select">
          <option>Sin asignar</option>
          <option>Oficial de Cumplimiento</option>
        </select>

        <label>Notas:</label>
        <textarea placeholder="Agregar nota..."></textarea>

        <button class="save-btn">Guardar nota</button>

      </aside>

    </section>

  </main>

<!-- SCRIPTS -->
<script src="/scripts/componentes.js"></script>
<script src="/scripts/buzon.js"></script>
<script src="https://unpkg.com/gridjs/dist/gridjs.umd.js"></script>

</body>
</html>